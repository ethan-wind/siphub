<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIP 详情</title>
    <script src="/lib/sequence-diagram-web.min.js"></script>
    <script src="/lib/jquery.min.js"></script>
    <link rel="stylesheet" href="/css/diagram.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Segoe UI', sans-serif;
            font-size: 13px;
            background: #f5f7fa;
            color: #1f2329;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .topbar {
            flex: 0 0 48px;
            background: #fff;
            border-bottom: 1px solid #e4e7ed;
            padding: 0 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 100;
        }
        .topbar a {
            color: #4e6ef2;
            text-decoration: none;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .topbar a:hover { text-decoration: underline; }
        .topbar-sep { color: #c8cdd6; }
        .topbar-title {
            font-size: 12px;
            color: #646a73;
            font-family: 'SF Mono', monospace;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 500px;
        }

        .page-body {
            flex: 1 1 auto;
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            min-height: 0;
            overflow: hidden;
        }

        /* ── Diagram area ── */
        .diagram-wrap {
            flex: 1 1 auto;
            min-width: 0;
            height: 100%;
            background: #fff;
            border: 1px solid #e4e7ed;
            border-radius: 6px;
            overflow: auto;
            padding: 16px;
        }
        #seq-a { display: inline-block; min-width: 100%; }
        #seq-a svg { display: block; }

        /* ── Toggle button (in topbar) ── */
        .detail-toggle {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            font-size: 12px;
            color: #646a73;
            background: #fff;
            border: 1px solid #e4e7ed;
            border-radius: 4px;
            cursor: pointer;
            transition: background 0.1s, color 0.1s, border-color 0.1s;
        }
        .detail-toggle:hover { background: #f0f2f5; }
        .detail-toggle.active { color: #4e6ef2; border-color: #4e6ef2; background: #eef1fe; }

        /* ── Detail sidebar ── */
        .msg-list {
            flex: 0 0 440px;
            height: 100%;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0;
        }
        .msg-list.hidden { display: none; }

        .msg-item {
            background: #fff;
            border: 1px solid #e4e7ed;
            border-top: none;
            cursor: pointer;
            transition: background 0.1s;
        }
        .msg-item:first-child { border-top: 1px solid #e4e7ed; border-radius: 6px 6px 0 0; }
        .msg-item:last-child  { border-radius: 0 0 6px 6px; }
        .msg-item:only-child  { border-radius: 6px; }
        .msg-item:hover { background: #f7f8fc; }
        .msg-item.active { background: #eef1fe; }

        .msg-item-header {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
        }
        .msg-index {
            font-size: 10px;
            font-weight: 700;
            color: #fff;
            background: #8a94a6;
            border-radius: 3px;
            padding: 1px 5px;
            flex-shrink: 0;
            font-family: monospace;
        }
        .msg-method {
            font-size: 12px;
            font-weight: 700;
            color: #4e6ef2;
        }
        .msg-meta {
            margin-left: auto;
            font-size: 11px;
            color: #8a94a6;
            font-family: 'SF Mono', monospace;
            white-space: nowrap;
        }
        .msg-raw {
            display: none;
            margin: 0 12px 8px;
            padding: 8px 10px;
            background: #f5f7fa;
            border: 1px solid #e4e7ed;
            border-radius: 4px;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 11px;
            line-height: 1.6;
            color: #334155;
            white-space: pre-wrap;
            word-break: break-all;
            max-height: 280px;
            overflow-y: auto;
        }
        .msg-item.active .msg-raw { display: block; }

        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-track { background: transparent; }
    </style>
</head>
<body>

<div class="topbar">
    <a href="javascript:history.back()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        返回
    </a>
    <span class="topbar-sep">/</span>
    <span class="topbar-title"><%= table[0] ? table[0].sip_call_id : '' %></span>
    <button class="detail-toggle" id="detailToggle">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6M3 15h6"/></svg>
        <span id="detailToggleLabel">显示信令详情</span>
    </button>
</div>

<div class="page-body">
    <div class="diagram-wrap">
        <div id="seq-a"></div>
    </div>

    <div class="msg-list hidden" id="msgList">
        <% for (let i = 0; i < table.length; i++) { let v = table[i]; %>
        <div class="msg-item" id="msg-<%= i %>" data-id="<%= i %>">
            <div class="msg-item-header">
                <span class="msg-index">F<%= i %></span>
                <span class="msg-method"><%= v.sip_method %></span>
                <span class="msg-meta"><%= v.create_time %> &nbsp;<%= v.sip_protocl %>/<%= v.msg_len %>B</span>
            </div>
            <pre class="msg-raw"><%= v.raw_msg %></pre>
        </div>
        <% } %>
    </div>
</div>

<script>
    const jq = jQuery
    const sd = SequenceDiagram
    const code = `<%- seq %>`
    const lineColors = ['#8A2BE2','#D2691E','#5F9EA0','#CD5C5C','#FF69B4','#90EE90','#FFA07A','#20B2AA','#87CEFA','#32CD32','#7B68EE','#C71585','#808000','#FF4500','#DA70D6','#00FF7F','#EE82EE','#9ACD32']
    const flow = [<%- table.map(it => it.cseq_number) %>]
    let gram

    // toggle detail panel
    const msgList = document.getElementById('msgList')
    const detailToggle = document.getElementById('detailToggle')
    const detailToggleLabel = document.getElementById('detailToggleLabel')
    detailToggle.addEventListener('click', function () {
        const hidden = msgList.classList.toggle('hidden')
        detailToggleLabel.textContent = hidden ? '显示信令详情' : '隐藏信令详情'
        detailToggle.classList.toggle('active', !hidden)
    })

    function setActive(id) {
        jq('.msg-item').removeClass('active')
        const el = document.getElementById(`msg-${id}`)
        if (el) { el.classList.add('active'); el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }) }
    }

    function init_diagram() {
        gram = new sd(code, { container: document.getElementById('seq-a') })

        gram.addEventListener('click', e => {
            if (e.type === 'connect') { gram.setHighlight(e.ln); setActive(e.ln) }
        })

        jq('.msg-item').on('click', function () {
            const id = parseInt(this.dataset.id)
            gram.setHighlight(id); setActive(id)
            jq('g.region.focus')[0]?.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
        })

        jq('g.region:has(polygon)').each(function (index) {
            const color = lineColors[flow[index] % lineColors.length]
            jq(this).find('path').first().css('stroke', color)
            jq(this).find('polygon').css('fill', color)
            jq(this).find('text').css('fill', color)
        })
    }

    jq(document).ready(init_diagram)
</script>
</body>
</html>
