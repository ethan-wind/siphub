<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIP 详情</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <script src="/lib/sequence-diagram-web.min.js"></script>
    <script src="/lib/jquery.min.js"></script>
    <link rel="stylesheet" href="/css/diagram.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body {
            min-height: 100%;
        }
        :root {
            --page-padding: 6px;
            --panel-gap: 12px;
            --detail-width: 430px;
            --topbar-height: 40px;
            --diagram-blue: #eef2f7;
            --diagram-green: #006b34;
            --diagram-orange: #ff7a00;
            --diagram-line: #8a8f98;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Segoe UI', sans-serif;
            font-size: 13px;
            background: #f5f9fc;
            color: #1f2329;
            overflow: auto;
        }

        .topbar {
            height: var(--topbar-height);
            background: #fff;
            border-bottom: 1px solid #e4e7ed;
            padding: 0 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 100;
        }
        .topbar a {
            color: #4e6ef2;
            text-decoration: none;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .topbar a:hover { text-decoration: underline; }
        .topbar-sep { color: #c8cdd6; }
        .topbar-title {
            font-size: 12px;
            color: #646a73;
            font-family: 'SF Mono', monospace;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 500px;
        }

        .page-body {
            width: 100vw;
            height: calc(100vh - var(--topbar-height));
            padding: var(--page-padding);
            display: grid;
            grid-template-columns: minmax(0, 1fr) var(--detail-width);
            gap: var(--panel-gap);
            overflow: hidden;
        }
        .page-body:has(.detail-panel.collapsed) {
            grid-template-columns: minmax(0, 1fr) 126px;
        }

        /* ── Diagram area (fixed canvas) ── */
        .diagram-wrap {
            min-width: 0;
            height: 100%;
            background: #fff;
            border: 0;
            border-radius: 0;
            overflow: auto;
            padding: 8px 4px 0;
        }
        #seq-a {
            display: block;
            width: max-content;
            min-width: 100%;
        }
        #seq-a svg {
            display: block;
            margin: 0;
            max-width: none;
            max-height: none;
        }
        #seq-a svg text {
            font-family: Arial, Helvetica, sans-serif;
        }
        #seq-a svg .endpoint-label {
            fill: #334155;
            font-size: 10px;
            font-weight: 700;
        }
        #seq-a svg .message-main {
            fill: #004cff;
            font-size: 7.6px;
            font-weight: 700;
        }
        #seq-a svg .message-meta {
            fill: #111827;
            font-size: 6.4px;
            font-weight: 400;
        }

        /* ── Detail panel (fixed 430px, collapsible) ── */
        .detail-panel {
            width: var(--detail-width);
            height: 100%;
            background: #fff;
            border: 1px solid #e4e7ed;
            border-radius: 6px;
            display: flex;
            overflow: hidden;
            transition: width 0.2s ease;
        }
        .detail-panel.collapsed { width: 126px; height: 34px; }

        .panel-collapse {
            flex-shrink: 0;
            width: 100%;
            height: 34px;
            background: linear-gradient(#f6f6f6, #e5e5e5);
            border: 1px solid #c8c8c8;
            border-radius: 4px;
            cursor: pointer;
            color: #2f343b;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            font-size: 14px;
            transition: background 0.1s, color 0.1s;
        }
        .panel-collapse:hover { background: linear-gradient(#fff, #e9e9e9); color: #111827; }
        .panel-collapse svg { width: 15px; height: 15px; }
        .panel-collapse-text::before { content: "隐藏信令详情"; }
        .detail-panel.collapsed .panel-collapse-text::before { content: "显示信令详情"; }
        .detail-panel:not(.collapsed) .panel-collapse {
            width: 4px;
            height: 100%;
            border: 0;
            border-right: 1px solid #e4e7ed;
            border-radius: 0;
            background: transparent;
            align-self: stretch;
            padding: 0;
        }
        .detail-panel:not(.collapsed) .panel-collapse svg { display: none; }
        .detail-panel:not(.collapsed) .panel-collapse-text { display: none; }

        .detail-panel-body {
            flex: 1 1 auto;
            min-width: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .detail-panel.collapsed .detail-panel-body { display: none; }

        .detail-panel-header {
            flex: 0 0 auto;
            padding: 10px 14px;
            border-bottom: 1px solid #e4e7ed;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .detail-panel-title {
            font-size: 13px;
            font-weight: 400;
            color: #1f2329;
        }
        .detail-panel-meta {
            font-size: 11px;
            color: #8a94a6;
            font-family: 'SF Mono', monospace;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .detail-raw {
            flex: 1 1 auto;
            margin: 0;
            padding: 12px 14px;
            background: #f7f8fc;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 11px;
            line-height: 1.7;
            color: #334155;
            white-space: pre-wrap;
            word-break: break-all;
            overflow-y: auto;
        }
        .detail-raw.empty {
            display: grid;
            place-items: center;
            color: #8a94a6;
            background: #fff;
            font-family: inherit;
            font-size: 12px;
        }

        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-track { background: transparent; }
    </style>
</head>
<body>

<div class="topbar">
    <a href="javascript:history.back()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        返回
    </a>
    <span class="topbar-sep">/</span>
    <span class="topbar-title"><%= table[0] ? table[0].sip_call_id : '' %></span>
</div>

<div class="page-body">
    <div class="diagram-wrap">
        <div id="seq-a"></div>
    </div>

    <aside class="detail-panel" id="detailPanel">
        <button class="panel-collapse" id="panelCollapse" type="button" aria-label="切换信令详情">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16M4 12h16M4 19h16"/><path d="M8 5v14"/></svg>
            <span class="panel-collapse-text"></span>
        </button>
        <div class="detail-panel-body">
            <div class="detail-panel-header">
                <span class="detail-panel-title">信令详情</span>
                <span class="detail-panel-meta" id="detailMeta">点击图中任意消息查看</span>
            </div>
            <pre class="detail-raw empty" id="detailRaw">点击序列图中的箭头查看报文详情</pre>
        </div>
    </aside>
</div>

<script>
    const jq = jQuery
    const sd = SequenceDiagram
    const code = `<%- seq %>`
    const msgLineOffset = <%= msgLineOffset || 0 %>
    const endpointLabel = {
        fontSize: 10,
        paddingX: 7,
        paddingY: 4,
    }
    const diagramCanvas = {
        margin: 5,
        zoom: 2.05,
    }
    const flow = [<%- table.map(it => it.cseq_number) %>]
    const MSG_DATA = <%- JSON.stringify(table.map((v, i) => ({
        index: i,
        method: v.sip_method,
        responseDesc: v.response_desc,
        time: v.create_time,
        timestampMicro: v.timestamp_micro,
        protocol: v.sip_protocl,
        size: v.msg_len,
        raw: v.raw_msg,
    }))).replace(/</g, '\\u003c') %>
    let gram

    const detailPanel = document.getElementById('detailPanel')
    const detailMeta  = document.getElementById('detailMeta')
    const detailRaw   = document.getElementById('detailRaw')

    function showMsg(id) {
        const m = MSG_DATA[id]
        if (!m) return
        detailMeta.textContent = `F${id} · ${m.method} · ${m.time} · ${m.protocol}/${m.size}B`
        detailRaw.textContent = m.raw
        detailRaw.classList.remove('empty')
        if (detailPanel.classList.contains('collapsed')) {
            detailPanel.classList.remove('collapsed')
        }
    }

    function selectDefaultMsg() {
        if (MSG_DATA.length === 0) return
        gram.setHighlight(msgLineOffset)
        showMsg(0)
    }

    document.getElementById('panelCollapse').addEventListener('click', () => {
        detailPanel.classList.toggle('collapsed')
    })

    function isEndpointLabel(text) {
        return /^\d{1,3}(?:\.\d{1,3}){3}_\d+$/.test(text.trim())
    }

    function clearText(text) {
        while (text.firstChild) text.removeChild(text.firstChild)
    }

    function addTspan(text, content, attrs = {}) {
        const tspan = document.createElementNS('http://www.w3.org/2000/svg', 'tspan')
        tspan.textContent = content
        Object.entries(attrs).forEach(([key, value]) => tspan.setAttribute(key, value))
        text.appendChild(tspan)
        return tspan
    }

    function findLabelBox(text) {
        const textBox = text.getBBox()
        const textCenter = {
            x: textBox.x + textBox.width / 2,
            y: textBox.y + textBox.height / 2,
        }
        let node = text.parentElement

        for (let i = 0; node && i < 4; i += 1, node = node.parentElement) {
            const rect = Array.from(node.querySelectorAll('rect')).find(item => {
                const x = parseFloat(item.getAttribute('x'))
                const y = parseFloat(item.getAttribute('y'))
                const width = parseFloat(item.getAttribute('width'))
                const height = parseFloat(item.getAttribute('height'))
                if ([x, y, width, height].some(Number.isNaN)) return false
                return textCenter.x >= x && textCenter.x <= x + width &&
                    textCenter.y >= y && textCenter.y <= y + height
            })

            if (rect) return rect
        }

        return null
    }

    function compactEndpointLabels() {
        const svg = document.querySelector('#seq-a svg')
        if (!svg) return

        Array.from(svg.querySelectorAll('text')).filter(text => isEndpointLabel(text.textContent)).forEach(text => {
            const rawLabel = text.textContent.trim()
            const originalBox = text.getBBox()
            const centerX = originalBox.x + originalBox.width / 2
            const centerY = originalBox.y + originalBox.height / 2

            clearText(text)
            text.setAttribute('font-size', endpointLabel.fontSize)
            text.setAttribute('font-weight', '700')
            text.style.fontSize = `${endpointLabel.fontSize}px`
            text.style.fontWeight = '700'
            text.classList.add('endpoint-label')
            addTspan(text, rawLabel, { x: centerX, y: centerY + 3 })

            const rect = findLabelBox(text)
            if (!rect) return

            const textBox = text.getBBox()
            const rectBox = rect.getBBox()
            const rectCenterX = rectBox.x + rectBox.width / 2
            const rectCenterY = rectBox.y + rectBox.height / 2
            const width = Math.ceil(textBox.width + endpointLabel.paddingX * 2)
            const height = Math.ceil(textBox.height + endpointLabel.paddingY * 2)

            rect.setAttribute('x', rectCenterX - width / 2)
            rect.setAttribute('y', rectCenterY - height / 2)
            rect.setAttribute('width', width)
            rect.setAttribute('height', height)
            rect.setAttribute('rx', 2)
            rect.setAttribute('ry', 2)
            rect.setAttribute('fill', '#eef2f7')
            rect.setAttribute('stroke', '#d8dee8')
        })
    }

    function parseMsgTime(m) {
        const base = Date.parse(String(m.time || '').replace(' ', 'T'))
        const micro = Number(m.timestampMicro || 0)
        return Number.isNaN(base) ? 0 : base + micro / 1000
    }

    function formatTimeLabel(m) {
        const parts = String(m.time || '').split(' ')
        return parts.length > 1 ? parts[1] : (m.time || '')
    }

    function formatDelta(index) {
        if (index <= 0) return '+0 ms'
        const prev = parseMsgTime(MSG_DATA[index - 1])
        const curr = parseMsgTime(MSG_DATA[index])
        const delta = Math.max(0, curr - prev)
        const value = delta >= 100 ? Math.round(delta) : Number(delta.toFixed(2))
        return `+${value} ms`
    }

    function isRequestMessage(m) {
        return !/^\d+$/.test(String(m.method || ''))
    }

    function mainMessageLabel(m) {
        if (isRequestMessage(m)) return m.method || ''
        return `${m.method || ''}${m.responseDesc ? ` [${m.responseDesc}]` : ''}`
    }

    function styleAgentLines() {
        const svg = document.querySelector('#seq-a svg')
        if (!svg) return

        Array.from(svg.querySelectorAll('line, path')).forEach(item => {
            const stroke = item.getAttribute('stroke') || item.style.stroke
            const fill = item.getAttribute('fill') || item.style.fill
            if (stroke !== '#000000' && stroke !== 'black') return
            if (fill && fill !== 'none') return

            const box = item.getBBox()
            if (box.height > 40 && box.width < 2) {
                item.setAttribute('stroke', '#8a8f98')
                item.setAttribute('stroke-width', '0.5')
                item.setAttribute('stroke-dasharray', '1.5,1.5')
            }
        })
    }

    function styleMessages() {
        jq('g.region:has(polygon)').each(function (index) {
            const m = MSG_DATA[index]
            if (!m) return
            const request = isRequestMessage(m)
            const color = request ? '#006b34' : '#ff7a00'
            const text = this.querySelector('text')
            const path = this.querySelector('path')

            jq(this).find('path').first().css({ stroke: color, 'stroke-width': 1.2 })
            jq(this).find('polygon').css({ fill: color, stroke: color })

            if (!text || !path) return
            const lineBox = path.getBBox()
            const centerX = lineBox.x + lineBox.width / 2
            const lineY = lineBox.y + lineBox.height / 2
            clearText(text)
            text.setAttribute('text-anchor', 'middle')
            text.setAttribute('font-family', 'Arial, Helvetica, sans-serif')
            text.setAttribute('font-size', '8')
            addTspan(text, mainMessageLabel(m), { x: centerX, y: lineY - 4, class: 'message-main' })
            addTspan(text, `[${index}] ${formatTimeLabel(m)} [${formatDelta(index)}]`, { x: centerX, y: lineY + 7, class: 'message-meta' })
        })
    }

    function normalizeDiagramCanvas() {
        const svg = document.querySelector('#seq-a svg')
        if (!svg) return

        const box = svg.getBBox()
        if (!box.width || !box.height) return

        const x = Math.floor(box.x - diagramCanvas.margin)
        const y = Math.floor(box.y - diagramCanvas.margin)
        const width = Math.ceil(box.width + diagramCanvas.margin * 2)
        const height = Math.ceil(box.height + diagramCanvas.margin * 2)
        const displayWidth = Math.ceil(width * diagramCanvas.zoom)
        const displayHeight = Math.ceil(height * diagramCanvas.zoom)

        svg.setAttribute('viewBox', `${x} ${y} ${width} ${height}`)
        svg.setAttribute('width', displayWidth)
        svg.setAttribute('height', displayHeight)
        svg.style.width = `${displayWidth}px`
        svg.style.height = `${displayHeight}px`
    }

    function init_diagram() {
        gram = new sd(code, { container: document.getElementById('seq-a') })
        compactEndpointLabels()
        styleAgentLines()
        styleMessages()
        normalizeDiagramCanvas()

        gram.addEventListener('click', e => {
            if (e.type === 'connect') { gram.setHighlight(e.ln); showMsg(e.ln - msgLineOffset) }
        })

        selectDefaultMsg()
    }

    jq(document).ready(init_diagram)
</script>
</body>
</html>
