<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <script src="/htmx-2.0.2/htmx.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #f0f2f5;
            --surface: #ffffff;
            --border: #e4e7ed;
            --border-light: #f0f2f5;
            --accent: #4e6ef2;
            --accent-hover: #3a5ce5;
            --accent-light: #eef1fe;
            --text: #1f2329;
            --text-secondary: #646a73;
            --text-placeholder: #bbbfc4;
            --danger: #f54a45;
            --success: #00b42a;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ── Top bar ── */
        .topbar {
            height: 48px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 0;
        }
        .topbar-brand {
            font-size: 15px;
            font-weight: 600;
            color: #000;
            display: flex;
            align-items: center;
            gap: 8px;
            padding-right: 20px;
            border-right: 1px solid var(--border);
            margin-right: 0;
            text-decoration: none;
        }
        .topbar-brand svg { color: #000; }
        .topbar-tab {
            display: flex;
            align-items: center;
            gap: 6px;
            height: 48px;
            padding: 0 16px;
            font-size: 13px;
            color: var(--accent);
            border-bottom: 2px solid var(--accent);
            margin-left: 4px;
            cursor: default;
            background: var(--accent-light);
        }
        .topbar-tab svg { width: 14px; height: 14px; }
        .logout-form { margin-left: auto; }
        .logout-btn {
            height: 30px;
            padding: 0 12px;
            border: 1px solid var(--border);
            border-radius: 4px;
            background: var(--surface);
            color: var(--text-secondary);
            font-size: 13px;
            cursor: pointer;
        }
        .logout-btn:hover { background: var(--bg); color: var(--text); }

        /* ── Search bar ── */
        .search-bar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 12px 20px;
        }
        .search-row {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .field-group {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .field-label {
            font-size: 13px;
            color: var(--text-secondary);
            white-space: nowrap;
            flex-shrink: 0;
        }
        .field-input {
            height: 32px;
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 0 10px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            outline: none;
            transition: border-color 0.15s;
        }
        .field-input:focus { border-color: var(--accent); }
        .field-input::placeholder { color: var(--text-placeholder); }
        .field-input.w-120 { width: 120px; }
        .field-input.w-160 { width: 160px; }
        .field-input.w-200 { width: 200px; }

        .divider { width: 1px; height: 20px; background: var(--border); margin: 0 4px; }

        .btn {
            height: 32px;
            padding: 0 16px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: background 0.15s, opacity 0.15s;
        }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-hover); }
        .btn-default { background: var(--surface); color: var(--text-secondary); border: 1px solid var(--border); }
        .btn-default:hover { background: var(--bg); }

        /* htmx */
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }

        /* ── Table area ── */
        .table-area {
            margin: 16px 20px;
            background: var(--surface);
            border-radius: 6px;
            border: 1px solid var(--border);
            overflow: hidden;
        }
        .table-toolbar {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 10px 16px;
            border-top: 1px solid var(--border-light);
            gap: 8px;
        }
        .result-count {
            font-size: 12px;
            color: var(--text-secondary);
            margin-right: auto;
        }

        table { width: 100%; border-collapse: collapse; }
        thead tr { background: var(--bg); }
        thead th {
            padding: 10px 16px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        tbody tr { border-bottom: 1px solid var(--border-light); transition: background 0.1s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #f7f8fc; }
        tbody td {
            padding: 11px 16px;
            font-size: 13px;
            color: var(--text);
            white-space: nowrap;
            vertical-align: middle;
        }
        .td-muted { color: var(--text-secondary); font-size: 12px; }
        .td-mono { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 12px; }
        .td-index {
            color: var(--text-secondary);
            font-size: 12px;
            font-family: monospace;
            width: 40px;
        }
        .link-caller {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }
        .link-caller:hover { text-decoration: underline; }

        /* empty */
        .empty-state {
            text-align: center;
            padding: 64px 20px;
            color: var(--text-secondary);
        }
        .empty-state svg { opacity: 0.25; display: block; margin: 0 auto 12px; }

        /* scrollbar */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-track { background: transparent; }

        /* time picker */
        .time-picker-wrap { position: relative; }
        .time-display {
            height: 32px; padding: 0 10px;
            border: 1px solid var(--border); border-radius: 4px;
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 13px; color: var(--text);
            background: var(--surface); cursor: pointer;
            white-space: nowrap; width: fit-content;
            transition: border-color 0.15s;
        }
        .time-display:focus { outline: none; border-color: var(--accent); }
        .time-display svg { color: var(--text-placeholder); flex-shrink: 0; }
        .time-popup {
            display: none; position: absolute; top: calc(100% + 4px); left: 0; z-index: 999;
            background: #fff; border: 1px solid var(--border); border-radius: 6px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.1); padding: 12px 16px 10px;
            min-width: 320px;
        }
        .time-popup.open { display: block; }
        .time-popup-header {
            display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
            text-align: center; font-size: 11px; font-weight: 600;
            color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .time-popup-preview {
            display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
            text-align: center; font-size: 15px; font-weight: 600;
            color: var(--accent); font-variant-numeric: tabular-nums;
            margin-bottom: 8px;
        }
        .time-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
        .time-col-group { display: flex; gap: 4px; justify-content: center; }
        .time-col { width: 36px; display: flex; flex-direction: column; align-items: center; gap: 0; }
        .time-col span {
            height: 32px; line-height: 32px; font-size: 14px; font-weight: 500;
            color: var(--text-secondary); width: 36px; text-align: center; border-radius: 4px;
            cursor: pointer; user-select: none; transition: background 0.1s, color 0.1s;
        }
        .time-col span:hover { background: var(--accent-light); }
        .time-col span.selected { color: var(--accent); font-weight: 700; }
        .time-col span.adj { font-size: 13px; color: #c8cdd6; }
        .time-col-sep { font-size: 16px; color: var(--text-secondary); line-height: 96px; align-self: center; }
        .time-popup-footer {
            display: flex; justify-content: flex-end; gap: 8px;
            margin-top: 10px; padding-top: 8px; border-top: 1px solid var(--border);
        }
        .time-popup-footer button {
            font-size: 12px; font-weight: 500; padding: 4px 14px;
            border-radius: 4px; border: none; cursor: pointer;
        }
        .btn-tp-cancel { background: transparent; color: var(--text-secondary); }
        .btn-tp-cancel:hover { color: var(--text); }
        .btn-tp-confirm { background: var(--accent); color: #fff; }
    </style>
</head>
<body>

<%- include('navbar') %>
<%- include('search', {day, start, stop}) %>

<div class="table-area">
    <div id="cdr">
        <%- include('sipcdr', {table}) %>
    </div>
    <div class="table-toolbar">
        <span class="result-count" id="result-count"></span>
        <button class="btn btn-default" onclick="document.querySelector('form').reset()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            重置
        </button>
    </div>
</div>

<script>
    // update result count after htmx swap
    document.body.addEventListener('htmx:afterSwap', () => {
        const rows = document.querySelectorAll('#cdr tbody tr').length;
        const el = document.getElementById('result-count');
        if (el) el.textContent = rows ? `共 ${rows} 条记录` : '';
    });
    // init count
    (function(){
        const rows = document.querySelectorAll('#cdr tbody tr').length;
        const el = document.getElementById('result-count');
        if (el && rows) el.textContent = `共 ${rows} 条记录`;
    })();
</script>
</body>
</html>
