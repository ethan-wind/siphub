<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <script src="/htmx-2.0.2/htmx.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #f0f2f5;
            --surface: #ffffff;
            --border: #e4e7ed;
            --border-light: #f0f2f5;
            --accent: #4e6ef2;
            --accent-hover: #3a5ce5;
            --accent-light: #eef1fe;
            --text: #1f2329;
            --text-secondary: #646a73;
            --text-placeholder: #bbbfc4;
            --danger: #f54a45;
            --success: #00b42a;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        button, input, select { font: inherit; }

        /* ── Top bar ── */
        .topbar {
            height: 48px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 0;
        }
        .topbar-brand {
            font-size: 15px;
            font-weight: 600;
            color: #000;
            display: flex;
            align-items: center;
            gap: 8px;
            padding-right: 20px;
            border-right: 1px solid var(--border);
            margin-right: 0;
            text-decoration: none;
        }
        .topbar-brand svg { color: #000; }
        .topbar-tab {
            display: flex;
            align-items: center;
            gap: 6px;
            height: 48px;
            padding: 0 16px;
            font-size: 13px;
            color: var(--accent);
            border-bottom: 2px solid var(--accent);
            margin-left: 4px;
            cursor: default;
            background: var(--accent-light);
        }
        .topbar-tab svg { width: 14px; height: 14px; }
        .logout-form { margin-left: auto; }
        .logout-btn {
            height: 30px;
            padding: 0 12px;
            border: 1px solid var(--border);
            border-radius: 4px;
            background: var(--surface);
            color: var(--text-secondary);
            font-size: 13px;
            cursor: pointer;
        }
        .logout-btn:hover { background: var(--bg); color: var(--text); }

        /* ── Search bar ── */
        .search-bar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 14px 20px;
            position: sticky;
            top: 0;
            z-index: 20;
        }
        .search-row {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex-wrap: wrap;
        }
        .search-main {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex: 1 1 860px;
            min-width: 0;
            flex-wrap: wrap;
            order: 1;
        }
        .field-group {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 5px;
            min-width: 0;
        }
        .field-group-time {
            flex-direction: row;
            align-items: flex-end;
            gap: 8px;
            flex-wrap: wrap;
        }
        .field-group-time .field-label {
            width: 100%;
        }
        .field-label {
            font-size: 12px;
            color: var(--text-secondary);
            white-space: nowrap;
            flex-shrink: 0;
            line-height: 1;
        }
        .field-input {
            height: 34px;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0 11px;
            font-size: 13px;
            color: var(--text);
            background: var(--surface);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .field-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(78,110,242,0.10);
        }
        .field-input::placeholder { color: var(--text-placeholder); }
        .field-input.w-120 { width: 120px; }
        .field-input.w-160 { width: 160px; }
        .field-input.w-180 { width: 180px; }
        .field-input.w-200 { width: 200px; }
        .field-input.w-280 { width: 280px; }

        .divider { width: 1px; height: 20px; background: var(--border); margin: 0 4px; }

        .btn {
            height: 34px;
            padding: 0 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: background 0.15s, opacity 0.15s;
            white-space: nowrap;
        }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-hover); }
        .btn-default { background: var(--surface); color: var(--text-secondary); border: 1px solid var(--border); }
        .btn-default:hover { background: var(--bg); }
        .btn-search {
            min-width: 90px;
            margin-top: 17px;
            justify-content: center;
            order: 2;
        }
        .btn-quick { padding: 0 12px; }
        .filter-more {
            flex: 1 0 100%;
            border-top: 1px solid var(--border-light);
            padding-top: 10px;
            order: 3;
        }
        .filter-more summary {
            width: fit-content;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 12px;
            list-style: none;
            user-select: none;
        }
        .filter-more summary::-webkit-details-marker { display: none; }
        .filter-more summary svg { transition: transform 0.15s; }
        .filter-more[open] summary svg { transform: rotate(180deg); }
        .filter-more-body {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            padding-top: 10px;
        }

        /* htmx */
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }

        /* ── Table area ── */
        .table-area {
            margin: 0 0 16px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            border-radius: 0;
            overflow: hidden;
        }
        #cdr {
            width: 100%;
            overflow-x: auto;
        }
        .table-toolbar {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 10px 16px;
            border-top: 1px solid var(--border-light);
            gap: 8px;
        }
        .result-count {
            font-size: 12px;
            color: var(--text-secondary);
            margin-right: auto;
        }

        table { width: 100%; min-width: 1180px; border-collapse: collapse; }
        thead tr { background: var(--bg); }
        thead th {
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 1;
            background: var(--bg);
        }
        tbody tr { border-bottom: 1px solid var(--border-light); transition: background 0.1s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #f7f8fc; }
        tbody td {
            padding: 11px 14px;
            font-size: 13px;
            color: var(--text);
            white-space: nowrap;
            vertical-align: middle;
        }
        .td-muted { color: var(--text-secondary); font-size: 12px; }
        .td-mono { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 12px; }
        .td-index {
            color: var(--text-secondary);
            font-size: 12px;
            font-family: monospace;
            width: 40px;
        }
        .td-host {
            max-width: 180px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .td-ua {
            max-width: 240px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            height: 22px;
            border-radius: 999px;
            padding: 0 8px;
            background: #eef6f0;
            color: #1f7a3d;
            font-size: 12px;
            font-weight: 600;
        }
        .status-pill.status-warn {
            background: #fff7e8;
            color: #a85f00;
        }
        .status-pill.status-error {
            background: #fff0f0;
            color: #c62828;
        }
        .status-pill.status-empty {
            background: var(--border-light);
            color: var(--text-secondary);
            font-weight: 500;
        }
        .method-pill {
            display: inline-flex;
            align-items: center;
            height: 22px;
            border-radius: 4px;
            padding: 0 7px;
            background: var(--accent-light);
            color: var(--accent);
            font-size: 12px;
            font-weight: 600;
        }
        .link-caller {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }
        .link-caller:hover { text-decoration: underline; }

        /* empty */
        .empty-state {
            text-align: center;
            padding: 64px 20px;
            color: var(--text-secondary);
        }
        .empty-state svg { opacity: 0.25; display: block; margin: 0 auto 12px; }

        /* scrollbar */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-track { background: transparent; }

        /* time picker */
        .time-picker-wrap { position: relative; }
        .time-display {
            height: 34px; padding: 0 11px;
            border: 1px solid var(--border); border-radius: 6px;
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 13px; color: var(--text);
            background: var(--surface); cursor: pointer;
            white-space: nowrap; width: fit-content;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .time-display:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(78,110,242,0.10);
        }
        .time-display svg { color: var(--text-placeholder); flex-shrink: 0; }
        .time-popup {
            display: none; position: absolute; top: calc(100% + 6px); left: 0; z-index: 999;
            background: #fff; border: 1px solid var(--border); border-radius: 6px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.1); padding: 12px 16px 10px;
            min-width: 320px;
        }
        .time-popup.open { display: block; }
        .time-popup-header {
            display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
            text-align: center; font-size: 11px; font-weight: 600;
            color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .time-popup-preview {
            display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
            text-align: center; font-size: 15px; font-weight: 600;
            color: var(--accent); font-variant-numeric: tabular-nums;
            margin-bottom: 8px;
        }
        .time-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
        .time-col-group { display: flex; gap: 4px; justify-content: center; }
        .time-col { width: 36px; display: flex; flex-direction: column; align-items: center; gap: 0; }
        .time-col span {
            height: 32px; line-height: 32px; font-size: 14px; font-weight: 500;
            color: var(--text-secondary); width: 36px; text-align: center; border-radius: 4px;
            cursor: pointer; user-select: none; transition: background 0.1s, color 0.1s;
        }
        .time-col span:hover { background: var(--accent-light); }
        .time-col span.selected { color: var(--accent); font-weight: 700; }
        .time-col span.adj { font-size: 13px; color: #c8cdd6; }
        .time-col-sep { font-size: 16px; color: var(--text-secondary); line-height: 96px; align-self: center; }
        .time-popup-footer {
            display: flex; justify-content: flex-end; gap: 8px;
            margin-top: 10px; padding-top: 8px; border-top: 1px solid var(--border);
        }
        .time-popup-footer button {
            font-size: 12px; font-weight: 500; padding: 4px 14px;
            border-radius: 4px; border: none; cursor: pointer;
        }
        .btn-tp-cancel { background: transparent; color: var(--text-secondary); }
        .btn-tp-cancel:hover { color: var(--text); }
        .btn-tp-confirm { background: var(--accent); color: #fff; }

        @media (max-width: 960px) {
            .search-bar { position: static; }
            .search-main { flex-basis: 100%; }
            .btn-search { margin-top: 0; flex: 1 1 120px; }
            .filter-more { order: 3; }
        }

        @media (max-width: 640px) {
            .topbar { padding: 0 12px; }
            .topbar-brand { padding-right: 12px; }
            .topbar-tab { padding: 0 10px; }
            .search-bar { padding: 12px; }
            .search-row, .search-main, .filter-more-body { gap: 8px; }
            .field-group,
            .field-group-time,
            .field-input,
            .field-input.w-120,
            .field-input.w-160,
            .field-input.w-180,
            .field-input.w-200,
            .field-input.w-280,
            .time-picker-wrap,
            .time-display,
            .btn-quick,
            .btn-search {
                width: 100%;
            }
            .time-display { justify-content: space-between; }
            .time-popup {
                position: fixed;
                left: 12px;
                right: 12px;
                top: 118px;
                min-width: 0;
            }
            .time-cols,
            .time-popup-header,
            .time-popup-preview {
                gap: 12px;
            }
            .table-toolbar { padding: 10px 12px; }
        }
    </style>
</head>
<body>

<%- include('navbar') %>
<%- include('search', {day, start, stop}) %>

<div class="table-area">
    <div id="cdr">
        <%- include('sipcdr', {table}) %>
    </div>
    <div class="table-toolbar">
        <span class="result-count" id="result-count"></span>
    </div>
</div>

<script>
    // update result count after htmx swap
    document.body.addEventListener('htmx:afterSwap', () => {
        const rows = document.querySelectorAll('#cdr tbody tr').length;
        const el = document.getElementById('result-count');
        if (el) el.textContent = rows ? `共 ${rows} 条记录` : '';
    });
    // init count
    (function(){
        const rows = document.querySelectorAll('#cdr tbody tr').length;
        const el = document.getElementById('result-count');
        if (el && rows) el.textContent = `共 ${rows} 条记录`;
    })();
</script>
</body>
</html>
