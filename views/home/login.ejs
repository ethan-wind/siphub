<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub 登录</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --accent: #5b63f6;
            --accent-hover: #4b55ed;
            --cyan: #31d0ba;
            --blue: #2ba8e8;
            --text: #1f2329;
            --muted: #8a94a6;
            --border: #dcdfe6;
            --danger: #f54a45;
        }
        body {
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            color: var(--text);
            overflow: hidden;
            background-color: #f3f1ff;
            background-image:
                radial-gradient(at 18% 22%, rgba(123, 132, 255, 0.45) 0%, transparent 55%),
                radial-gradient(at 82% 18%, rgba(180, 158, 255, 0.50) 0%, transparent 55%),
                radial-gradient(at 75% 82%, rgba(143, 196, 255, 0.45) 0%, transparent 55%),
                radial-gradient(at 22% 88%, rgba(173, 230, 218, 0.40) 0%, transparent 55%);
        }
        .login-page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .login-card {
            width: min(432px, 100%);
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 14px;
            padding: 28px 28px 20px;
            box-shadow: 0 20px 40px rgba(91, 99, 246, 0.18), 0 2px 6px rgba(91, 99, 246, 0.06);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 8px;
        }
        .logo {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6e76ff 0%, #5b63f6 50%, #4b55ed 100%);
            box-shadow: 0 6px 14px rgba(91, 99, 246, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.25);
            display: grid;
            place-items: center;
            flex-shrink: 0;
            color: #fff;
        }
        .brand-name {
            font-size: 26px;
            font-weight: 700;
            color: var(--accent);
            line-height: 1.1;
            letter-spacing: 0.2px;
        }
        .sub-title {
            font-size: 13px;
            color: var(--muted);
            margin: 0 0 22px 62px;
        }
        .field {
            position: relative;
            margin-bottom: 24px;
        }
        .field.compact { margin-bottom: 14px; }
        .input {
            width: 100%;
            height: 32px;
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 0 12px;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(91, 99, 246, 0.12);
        }
        .input::placeholder { color: #b8bdc7; }
        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            border: 0;
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            display: grid;
            place-items: center;
        }
        .captcha-row {
            display: grid;
            grid-template-columns: 1fr 100px;
            gap: 20px;
            align-items: center;
        }
        .captcha-img {
            width: 100px;
            height: 32px;
            object-fit: cover;
            cursor: pointer;
        }
        .remember {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #303744;
            font-size: 13px;
            margin: 2px 0 24px;
            user-select: none;
        }
        .remember input {
            width: 16px;
            height: 16px;
            accent-color: var(--accent);
        }
        .error {
            min-height: 18px;
            margin: -10px 0 10px;
            color: var(--danger);
            font-size: 13px;
        }
        .submit {
            width: 100%;
            height: 40px;
            border: 0;
            border-radius: 20px;
            background: var(--accent);
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s, transform 0.15s;
        }
        .submit:hover { background: var(--accent-hover); }
        .submit:active { transform: translateY(1px); }

        @media (max-width: 520px) {
            body { overflow: auto; }
            .login-card { padding: 22px 18px 16px; }
            .brand-name { font-size: 23px; }
            .sub-title { margin-left: 58px; }
            .captcha-row { grid-template-columns: 1fr 96px; gap: 10px; }
        }
    </style>
</head>
<body>
<main class="login-page">
    <form class="login-card" method="post" action="/login" autocomplete="on">
        <div class="brand">
            <div class="logo" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                    <line x1="4" y1="11" x2="4" y2="13"/>
                    <line x1="8.5" y1="8" x2="8.5" y2="16"/>
                    <line x1="12" y1="4" x2="12" y2="20"/>
                    <line x1="15.5" y1="7" x2="15.5" y2="17"/>
                    <line x1="20" y1="10" x2="20" y2="14"/>
                </svg>
            </div>
            <div class="brand-name">SIPHub</div>
        </div>

        <div class="sub-title">登录账号以继续</div>

        <div class="field">
            <input class="input" name="username" type="text" placeholder="请输入用户名" autocomplete="username" required autofocus>
        </div>

        <div class="field">
            <input class="input" id="password" name="password" type="password" placeholder="请输入密码" autocomplete="current-password" required>
            <button class="password-toggle" type="button" id="togglePassword" aria-label="显示或隐藏密码">
                <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l18 18"/><path d="M10.6 10.6a2 2 0 102.8 2.8"/><path d="M9.9 4.2A10.8 10.8 0 0112 4c7 0 10 8 10 8a15.5 15.5 0 01-3.2 4.7"/><path d="M6.6 6.6C3.4 8.8 2 12 2 12s3 8 10 8a10.7 10.7 0 005.4-1.5"/></svg>
            </button>
        </div>

        <div class="field compact captcha-row">
            <input class="input" name="captcha" type="text" placeholder="请输入验证码" autocomplete="off" required>
            <img class="captcha-img" id="captchaImg" src="/captcha" alt="验证码" title="点击刷新验证码">
        </div>

        <label class="remember">
            <input type="checkbox" name="remember">
            记住我
        </label>

        <div class="error"><%= error %></div>

        <button class="submit" type="submit">确认</button>
    </form>
</main>

<script>
    const captchaImg = document.getElementById('captchaImg')
    captchaImg.addEventListener('click', function () {
        this.src = '/captcha?t=' + Date.now()
    })

    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('password')
        input.type = input.type === 'password' ? 'text' : 'password'
    })
</script>
</body>
</html>
