<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub 登录</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --accent: #5b63f6;
            --accent-hover: #4b55ed;
            --cyan: #31d0ba;
            --blue: #2ba8e8;
            --text: #1f2329;
            --muted: #8a94a6;
            --border: #dcdfe6;
            --danger: #f54a45;
        }
        body {
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            color: var(--text);
            overflow: hidden;
            background-color: #f7f7f8;
            background-image:
                radial-gradient(circle at 4% 5%, rgba(255, 203, 204, 0.72) 0 0, rgba(255, 203, 204, 0.42) 12%, rgba(255, 203, 204, 0.18) 23%, transparent 38%),
                radial-gradient(circle at 61% 76%, rgba(255, 238, 133, 0.36) 0 0, rgba(255, 238, 133, 0.24) 12%, rgba(255, 238, 133, 0.10) 24%, transparent 41%),
                radial-gradient(circle at 95% 93%, rgba(166, 239, 234, 0.58) 0 0, rgba(166, 239, 234, 0.34) 14%, rgba(166, 239, 234, 0.16) 27%, transparent 45%),
                linear-gradient(180deg, #f8f8f9 0%, #f5f5f6 100%);
        }
        .page-brand {
            position: fixed;
            top: 16px;
            left: 24px;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: #050505;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.2px;
        }
        .page-brand svg {
            width: 40px;
            height: 30px;
            filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.08));
        }
        .login-page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 96px 24px 64px;
        }
        .login-stack {
            width: min(446px, 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .auth-brand {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            margin-bottom: 28px;
            color: var(--accent);
            font-size: 26px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }
        .logo {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6e76ff 0%, #5b63f6 50%, #4b55ed 100%);
            box-shadow: 0 6px 14px rgba(91, 99, 246, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.25);
            display: grid;
            place-items: center;
            flex-shrink: 0;
            color: #fff;
        }
        .login-card {
            width: 100%;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.06);
            border-radius: 20px;
            padding: 36px 28px 20px;
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.10), 0 1px 0 rgba(255, 255, 255, 0.8) inset;
        }
        .login-title {
            text-align: center;
            font-size: 25px;
            font-weight: 800;
            letter-spacing: 6px;
            color: #20242a;
            margin: 0 0 48px 6px;
        }
        .field {
            position: relative;
            margin-bottom: 24px;
        }
        .field.compact { margin-bottom: 14px; }
        .input {
            width: 100%;
            height: 32px;
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 0 12px;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(91, 99, 246, 0.12);
        }
        .input::placeholder { color: #b8bdc7; }
        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            border: 0;
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            display: grid;
            place-items: center;
        }
        .captcha-row {
            display: grid;
            grid-template-columns: 1fr 100px;
            gap: 20px;
            align-items: center;
        }
        .captcha-img {
            width: 100px;
            height: 32px;
            object-fit: cover;
            cursor: pointer;
        }
        .remember {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #303744;
            font-size: 13px;
            margin: 2px 0 24px;
            user-select: none;
        }
        .remember input {
            width: 16px;
            height: 16px;
            accent-color: var(--accent);
        }
        .error {
            min-height: 18px;
            margin: -10px 0 10px;
            color: var(--danger);
            font-size: 13px;
        }
        .submit {
            width: 100%;
            height: 40px;
            border: 0;
            border-radius: 20px;
            background: var(--accent);
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s, transform 0.15s;
        }
        .submit:hover { background: var(--accent-hover); }
        .submit:active { transform: translateY(1px); }

        @media (max-width: 520px) {
            body { overflow: auto; }
            .page-brand {
                top: 14px;
                left: 16px;
                font-size: 16px;
            }
            .page-brand svg { width: 34px; height: 26px; }
            .login-page { padding: 88px 18px 40px; }
            .auth-brand {
                gap: 10px;
                margin-bottom: 22px;
                font-size: 23px;
            }
            .logo {
                width: 44px;
                height: 44px;
            }
            .login-card { padding: 22px 18px 16px; }
            .login-title {
                font-size: 23px;
                margin-bottom: 34px;
            }
            .captcha-row { grid-template-columns: 1fr 96px; gap: 10px; }
        }
    </style>
</head>
<body>
<div class="page-brand" aria-label="SIPHub">
    <svg viewBox="0 0 64 44" fill="none" aria-hidden="true">
        <path d="M11 30.5 23 14h25c5.5 0 8.5 3 7.4 7.5L54 27c-1.2 5-5.5 8-11 8H22l-8 7H5l6-11.5Z" stroke="currentColor" stroke-width="4.5" stroke-linejoin="round"/>
        <path d="M18 27 26 19h21c2.6 0 4 .9 3.6 2.7l-.5 2.3c-.4 1.8-2.1 2.9-4.8 2.9H27l-6.7 5.7H12L18 27Z" stroke="currentColor" stroke-width="4.5" stroke-linejoin="round"/>
    </svg>
    <span>SIPHub</span>
</div>
<main class="login-page">
    <div class="login-stack">
        <div class="auth-brand" aria-label="SIPHub">
            <div class="logo" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                    <line x1="4" y1="11" x2="4" y2="13"/>
                    <line x1="8.5" y1="8" x2="8.5" y2="16"/>
                    <line x1="12" y1="4" x2="12" y2="20"/>
                    <line x1="15.5" y1="7" x2="15.5" y2="17"/>
                    <line x1="20" y1="10" x2="20" y2="14"/>
                </svg>
            </div>
            <span>SIPHub</span>
        </div>

        <form class="login-card" method="post" action="/login" autocomplete="on">
            <div class="login-title">登录</div>

            <div class="field">
                <input class="input" name="username" type="text" placeholder="请输入用户名" autocomplete="username" required autofocus>
            </div>

            <div class="field">
                <input class="input" id="password" name="password" type="password" placeholder="请输入密码" autocomplete="current-password" required>
                <button class="password-toggle" type="button" id="togglePassword" aria-label="显示或隐藏密码">
                    <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l18 18"/><path d="M10.6 10.6a2 2 0 102.8 2.8"/><path d="M9.9 4.2A10.8 10.8 0 0112 4c7 0 10 8 10 8a15.5 15.5 0 01-3.2 4.7"/><path d="M6.6 6.6C3.4 8.8 2 12 2 12s3 8 10 8a10.7 10.7 0 005.4-1.5"/></svg>
                </button>
            </div>

            <div class="field compact captcha-row">
                <input class="input" name="captcha" type="text" placeholder="请输入验证码" autocomplete="off" required>
                <img class="captcha-img" id="captchaImg" src="/captcha" alt="验证码" title="点击刷新验证码">
            </div>

            <label class="remember">
                <input type="checkbox" name="remember">
                记住我
            </label>

            <div class="error"><%= error %></div>

            <button class="submit" type="submit">确认</button>
        </form>
    </div>
</main>

<script>
    const captchaImg = document.getElementById('captchaImg')
    captchaImg.addEventListener('click', function () {
        this.src = '/captcha?t=' + Date.now()
    })

    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('password')
        input.type = input.type === 'password' ? 'text' : 'password'
    })
</script>
</body>
</html>
