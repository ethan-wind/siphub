<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub 登录</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --accent: #5b63f6;
            --accent-hover: #4b55ed;
            --cyan: #31d0ba;
            --blue: #2ba8e8;
            --text: #1f2329;
            --muted: #8a94a6;
            --border: #dcdfe6;
            --danger: #f54a45;
        }
        body {
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            background: #dedbfb;
            color: var(--text);
            overflow: hidden;
        }
        body::before,
        body::after {
            content: "";
            position: fixed;
            pointer-events: none;
            z-index: 0;
        }
        body::before {
            width: 740px;
            height: 430px;
            right: -80px;
            top: -40px;
            border-radius: 52% 48% 48% 52% / 42% 45% 55% 58%;
            background: linear-gradient(120deg, #7278f6 0%, #b5c0ff 100%);
        }
        body::after {
            width: 430px;
            height: 500px;
            left: -70px;
            bottom: -170px;
            border-radius: 48% 52% 54% 46% / 44% 45% 55% 56%;
            background: linear-gradient(160deg, #cdd9ff 0%, #aab6ff 100%);
            opacity: 0.75;
        }
        .login-page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .login-card {
            width: min(432px, 100%);
            background: #fff;
            border-radius: 10px;
            padding: 18px 16px 12px;
            box-shadow: 0 10px 30px rgba(78, 110, 242, 0.12);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }
        .logo {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, var(--cyan), var(--blue), var(--cyan));
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }
        .logo::after {
            content: "";
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: #fff;
            box-shadow: inset 10px 0 0 #e7f9f6;
        }
        .brand-name {
            font-size: 26px;
            font-weight: 700;
            color: #3084f2;
            line-height: 1.1;
        }
        .brand-mark {
            margin-left: auto;
            width: 16px;
            height: 16px;
            background: linear-gradient(90deg, #777, #c8c8c8);
            clip-path: polygon(0 0, 70% 0, 70% 30%, 100% 30%, 100% 100%, 30% 100%, 30% 70%, 0 70%);
            opacity: 0.7;
        }
        .sub-title {
            font-size: 15px;
            font-weight: 600;
            color: #4e8ff4;
            margin-bottom: 24px;
        }
        .field {
            position: relative;
            margin-bottom: 24px;
        }
        .field.compact { margin-bottom: 14px; }
        .input {
            width: 100%;
            height: 32px;
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 0 12px;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(91, 99, 246, 0.12);
        }
        .input::placeholder { color: #b8bdc7; }
        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            border: 0;
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            display: grid;
            place-items: center;
        }
        .captcha-row {
            display: grid;
            grid-template-columns: 1fr 100px;
            gap: 20px;
            align-items: center;
        }
        .captcha-img {
            width: 100px;
            height: 32px;
            object-fit: cover;
            cursor: pointer;
        }
        .remember {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #303744;
            font-size: 13px;
            margin: 2px 0 24px;
            user-select: none;
        }
        .remember input {
            width: 16px;
            height: 16px;
            accent-color: var(--accent);
        }
        .error {
            min-height: 18px;
            margin: -10px 0 10px;
            color: var(--danger);
            font-size: 13px;
        }
        .submit {
            width: 100%;
            height: 40px;
            border: 0;
            border-radius: 20px;
            background: var(--accent);
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s, transform 0.15s;
        }
        .submit:hover { background: var(--accent-hover); }
        .submit:active { transform: translateY(1px); }

        @media (max-width: 520px) {
            body { overflow: auto; }
            body::before { width: 460px; height: 300px; right: -190px; }
            body::after { width: 330px; height: 410px; left: -180px; }
            .login-card { padding: 18px 16px 14px; }
            .brand-name { font-size: 23px; }
            .captcha-row { grid-template-columns: 1fr 96px; gap: 10px; }
        }
    </style>
</head>
<body>
<main class="login-page">
    <form class="login-card" method="post" action="/login" autocomplete="on">
        <div class="brand">
            <div class="logo" aria-hidden="true"></div>
            <div class="brand-name">SIPHub</div>
            <div class="brand-mark" aria-hidden="true"></div>
        </div>

        <div class="sub-title">登录</div>

        <div class="field">
            <input class="input" name="username" type="text" placeholder="请输入用户名" autocomplete="username" required autofocus>
        </div>

        <div class="field">
            <input class="input" id="password" name="password" type="password" placeholder="请输入密码" autocomplete="current-password" required>
            <button class="password-toggle" type="button" id="togglePassword" aria-label="显示或隐藏密码">
                <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l18 18"/><path d="M10.6 10.6a2 2 0 102.8 2.8"/><path d="M9.9 4.2A10.8 10.8 0 0112 4c7 0 10 8 10 8a15.5 15.5 0 01-3.2 4.7"/><path d="M6.6 6.6C3.4 8.8 2 12 2 12s3 8 10 8a10.7 10.7 0 005.4-1.5"/></svg>
            </button>
        </div>

        <div class="field compact captcha-row">
            <input class="input" name="captcha" type="text" placeholder="请输入验证码" autocomplete="off" required>
            <img class="captcha-img" id="captchaImg" src="/captcha" alt="验证码" title="点击刷新验证码">
        </div>

        <label class="remember">
            <input type="checkbox" name="remember">
            记住我
        </label>

        <div class="error"><%= error %></div>

        <button class="submit" type="submit">确认</button>
    </form>
</main>

<script>
    const captchaImg = document.getElementById('captchaImg')
    captchaImg.addEventListener('click', function () {
        this.src = '/captcha?t=' + Date.now()
    })

    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('password')
        input.type = input.type === 'password' ? 'text' : 'password'
    })
</script>
</body>
</html>
