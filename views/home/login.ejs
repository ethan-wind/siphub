<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SIPHub 登录</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --accent: #5b63f6;
            --accent-hover: #4b55ed;
            --cyan: #31d0ba;
            --blue: #2ba8e8;
            --text: #1f2329;
            --muted: #8a94a6;
            --border: #dcdfe6;
            --danger: #f54a45;
        }
        body {
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
            color: var(--text);
            overflow: hidden;
            background-color: #f7f7f8;
            background-image:
                radial-gradient(circle at 4% 5%, rgba(255, 203, 204, 0.72) 0 0, rgba(255, 203, 204, 0.42) 12%, rgba(255, 203, 204, 0.18) 23%, transparent 38%),
                radial-gradient(circle at 61% 76%, rgba(255, 238, 133, 0.36) 0 0, rgba(255, 238, 133, 0.24) 12%, rgba(255, 238, 133, 0.10) 24%, transparent 41%),
                radial-gradient(circle at 95% 93%, rgba(166, 239, 234, 0.58) 0 0, rgba(166, 239, 234, 0.34) 14%, rgba(166, 239, 234, 0.16) 27%, transparent 45%),
                linear-gradient(180deg, #f8f8f9 0%, #f5f5f6 100%);
        }
        .page-brand {
            position: fixed;
            top: 16px;
            left: 24px;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: #050505;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.2px;
        }
        .login-page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 96px 24px 64px;
        }
        .login-stack {
            width: min(446px, 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .auth-brand {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            margin-bottom: 28px;
            color: var(--accent);
            font-size: 26px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }
        .logo {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6e76ff 0%, #5b63f6 50%, #4b55ed 100%);
            box-shadow: 0 6px 14px rgba(91, 99, 246, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.25);
            display: grid;
            place-items: center;
            flex-shrink: 0;
            color: #fff;
        }
        .page-brand .logo {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(91, 99, 246, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.25);
        }
        .page-brand .logo svg {
            width: 20px;
            height: 20px;
        }
        .login-card {
            width: 100%;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.06);
            border-radius: 20px;
            padding: 36px 28px 20px;
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.10), 0 1px 0 rgba(255, 255, 255, 0.8) inset;
        }
        .login-title {
            text-align: center;
            font-size: 25px;
            font-weight: 800;
            letter-spacing: 6px;
            color: #20242a;
            margin: 0 0 48px 6px;
        }
        .field {
            position: relative;
            margin-bottom: 24px;
        }
        .field.compact { margin-bottom: 14px; }
        .input {
            width: 100%;
            height: 32px;
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 0 12px;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(91, 99, 246, 0.12);
        }
        .input::placeholder { color: #b8bdc7; }
        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            border: 0;
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            display: grid;
            place-items: center;
        }
        .captcha-row {
            display: grid;
            grid-template-columns: 1fr 100px;
            gap: 20px;
            align-items: center;
        }
        .captcha-img {
            width: 100px;
            height: 32px;
            object-fit: cover;
            cursor: pointer;
        }
        .remember {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #303744;
            font-size: 13px;
            margin: 2px 0 24px;
            user-select: none;
        }
        .remember input {
            width: 16px;
            height: 16px;
            accent-color: var(--accent);
        }
        .error {
            min-height: 18px;
            margin: -10px 0 10px;
            color: var(--danger);
            font-size: 13px;
        }
        .submit {
            width: 100%;
            height: 40px;
            border: 0;
            border-radius: 20px;
            background: var(--accent);
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s, transform 0.15s;
        }
        .submit:hover { background: var(--accent-hover); }
        .submit:active { transform: translateY(1px); }

        @media (max-width: 520px) {
            body { overflow: auto; }
            .page-brand {
                top: 14px;
                left: 16px;
                font-size: 16px;
            }
            .page-brand .logo {
                width: 30px;
                height: 30px;
                border-radius: 7px;
            }
            .page-brand .logo svg {
                width: 18px;
                height: 18px;
            }
            .login-page { padding: 88px 18px 40px; }
            .auth-brand {
                gap: 10px;
                margin-bottom: 22px;
                font-size: 23px;
            }
            .logo {
                width: 44px;
                height: 44px;
            }
            .login-card { padding: 22px 18px 16px; }
            .login-title {
                font-size: 23px;
                margin-bottom: 34px;
            }
            .captcha-row { grid-template-columns: 1fr 96px; gap: 10px; }
        }
    </style>
</head>
<body>
<div class="page-brand" aria-label="SIPHub">
    <div class="logo" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <line x1="4" y1="11" x2="4" y2="13"/>
            <line x1="8.5" y1="8" x2="8.5" y2="16"/>
            <line x1="12" y1="4" x2="12" y2="20"/>
            <line x1="15.5" y1="7" x2="15.5" y2="17"/>
            <line x1="20" y1="10" x2="20" y2="14"/>
        </svg>
    </div>
    <span>SIPHub</span>
</div>
<main class="login-page">
    <div class="login-stack">
        <div class="auth-brand" aria-label="SIPHub">
            <div class="logo" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                    <line x1="4" y1="11" x2="4" y2="13"/>
                    <line x1="8.5" y1="8" x2="8.5" y2="16"/>
                    <line x1="12" y1="4" x2="12" y2="20"/>
                    <line x1="15.5" y1="7" x2="15.5" y2="17"/>
                    <line x1="20" y1="10" x2="20" y2="14"/>
                </svg>
            </div>
            <span>SIPHub</span>
        </div>

        <form class="login-card" id="loginForm" method="post" action="/login" autocomplete="on">
            <div class="login-title">登录</div>
            <input type="hidden" id="passwordHash" name="passwordHash">
            <input type="hidden" id="loginChallenge" name="loginChallenge" value="<%= loginChallenge %>">

            <div class="field">
                <input class="input" name="username" type="text" placeholder="请输入用户名" autocomplete="username" required autofocus>
            </div>

            <div class="field">
                <input class="input" id="password" type="password" placeholder="请输入密码" autocomplete="current-password" required>
                <button class="password-toggle" type="button" id="togglePassword" aria-label="显示或隐藏密码">
                    <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l18 18"/><path d="M10.6 10.6a2 2 0 102.8 2.8"/><path d="M9.9 4.2A10.8 10.8 0 0112 4c7 0 10 8 10 8a15.5 15.5 0 01-3.2 4.7"/><path d="M6.6 6.6C3.4 8.8 2 12 2 12s3 8 10 8a10.7 10.7 0 005.4-1.5"/></svg>
                </button>
            </div>

            <div class="field compact captcha-row">
                <input class="input" name="captcha" type="text" placeholder="请输入验证码" autocomplete="off" required>
                <img class="captcha-img" id="captchaImg" src="/captcha" alt="验证码" title="点击刷新验证码">
            </div>

            <label class="remember">
                <input type="checkbox" name="remember">
                记住我
            </label>

            <div class="error"><%= error %></div>

            <button class="submit" type="submit">确认</button>
        </form>
    </div>
</main>

<script>
    async function sha256Hex(message) {
        if (window.crypto && window.crypto.subtle) {
            const bytes = new TextEncoder().encode(message)
            const hash = await window.crypto.subtle.digest('SHA-256', bytes)
            return Array.from(new Uint8Array(hash), b => b.toString(16).padStart(2, '0')).join('')
        }

        return sha256HexFallback(message)
    }

    function sha256HexFallback(message) {
        function rightRotate(value, amount) {
            return (value >>> amount) | (value << (32 - amount))
        }

        const bytes = Array.from(unescape(encodeURIComponent(message)), c => c.charCodeAt(0))
        const bitLength = bytes.length * 8
        bytes.push(0x80)
        while (bytes.length % 64 !== 56) bytes.push(0)
        for (let i = 7; i >= 0; i--) bytes.push((bitLength / Math.pow(256, i)) & 255)

        const k = [
            0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
            0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
            0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
            0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
            0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
            0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
            0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
            0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
        ]
        const h = [0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a, 0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19]

        for (let i = 0; i < bytes.length; i += 64) {
            const w = new Array(64)
            for (let j = 0; j < 16; j++) {
                w[j] = (bytes[i + j * 4] << 24) | (bytes[i + j * 4 + 1] << 16) | (bytes[i + j * 4 + 2] << 8) | bytes[i + j * 4 + 3]
            }
            for (let j = 16; j < 64; j++) {
                const s0 = rightRotate(w[j - 15], 7) ^ rightRotate(w[j - 15], 18) ^ (w[j - 15] >>> 3)
                const s1 = rightRotate(w[j - 2], 17) ^ rightRotate(w[j - 2], 19) ^ (w[j - 2] >>> 10)
                w[j] = (w[j - 16] + s0 + w[j - 7] + s1) | 0
            }

            let [a, b, c, d, e, f, g, hh] = h
            for (let j = 0; j < 64; j++) {
                const s1 = rightRotate(e, 6) ^ rightRotate(e, 11) ^ rightRotate(e, 25)
                const ch = (e & f) ^ (~e & g)
                const temp1 = (hh + s1 + ch + k[j] + w[j]) | 0
                const s0 = rightRotate(a, 2) ^ rightRotate(a, 13) ^ rightRotate(a, 22)
                const maj = (a & b) ^ (a & c) ^ (b & c)
                const temp2 = (s0 + maj) | 0
                hh = g
                g = f
                f = e
                e = (d + temp1) | 0
                d = c
                c = b
                b = a
                a = (temp1 + temp2) | 0
            }

            h[0] = (h[0] + a) | 0
            h[1] = (h[1] + b) | 0
            h[2] = (h[2] + c) | 0
            h[3] = (h[3] + d) | 0
            h[4] = (h[4] + e) | 0
            h[5] = (h[5] + f) | 0
            h[6] = (h[6] + g) | 0
            h[7] = (h[7] + hh) | 0
        }

        return h.map(value => (value >>> 0).toString(16).padStart(8, '0')).join('')
    }

    const captchaImg = document.getElementById('captchaImg')
    captchaImg.addEventListener('click', function () {
        this.src = '/captcha?t=' + Date.now()
    })

    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('password')
        input.type = input.type === 'password' ? 'text' : 'password'
    })

    document.getElementById('loginForm').addEventListener('submit', async function (event) {
        event.preventDefault()

        const username = this.elements.username.value
        const password = document.getElementById('password').value
        const challenge = document.getElementById('loginChallenge').value
        document.getElementById('passwordHash').value = await sha256Hex(`${username}:${password}:${challenge}`)
        document.getElementById('password').value = ''
        this.submit()
    })
</script>
</body>
</html>
