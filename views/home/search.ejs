<div class="search-bar">
    <form class="search-row" hx-post="/api/record" hx-target="#cdr" hx-swap="innerHTML">
        <div class="search-main">
            <div class="field-group">
                <label class="field-label" for="caller">主叫</label>
                <input id="caller" name="caller" type="text" placeholder="号码，支持 * 通配" class="field-input w-180" autocomplete="off">
            </div>

            <div class="field-group">
                <label class="field-label" for="callee">被叫</label>
                <input id="callee" name="callee" type="text" placeholder="号码，支持 * 通配" class="field-input w-180" autocomplete="off">
            </div>

            <div class="field-group">
                <label class="field-label" for="callid">CALL-ID</label>
                <input id="callid" name="callid" type="text" placeholder="精确匹配 Call-ID" class="field-input w-280" autocomplete="off">
            </div>

            <div class="field-group">
                <label class="field-label" for="day">日期</label>
                <input id="day" name="day" type="date" value="<%= day %>" class="field-input w-160">
            </div>

            <div class="field-group field-group-time">
                <span class="field-label">时间</span>
                <div class="time-picker-wrap">
                    <div class="time-display" tabindex="0" id="timeDisplay" role="button" aria-haspopup="dialog">
                        <span id="timeDisplayText"><%= start %> 至 <%= stop %></span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                    <input type="hidden" name="start" id="inputStart" value="<%= start %>">
                    <input type="hidden" name="stop"  id="inputStop"  value="<%= stop %>">
                    <div class="time-popup" id="timePopup">
                        <div class="time-popup-header"><div>开始时间</div><div>结束时间</div></div>
                        <div class="time-popup-preview"><div id="previewStart"></div><div id="previewEnd"></div></div>
                        <div class="time-cols">
                            <div class="time-col-group">
                                <div class="time-col" id="col-sh"></div>
                                <span class="time-col-sep">:</span>
                                <div class="time-col" id="col-sm"></div>
                                <span class="time-col-sep">:</span>
                                <div class="time-col" id="col-ss"></div>
                            </div>
                            <div class="time-col-group">
                                <div class="time-col" id="col-eh"></div>
                                <span class="time-col-sep">:</span>
                                <div class="time-col" id="col-em"></div>
                                <span class="time-col-sep">:</span>
                                <div class="time-col" id="col-es"></div>
                            </div>
                        </div>
                        <div class="time-popup-footer">
                            <button type="button" class="btn-tp-cancel" id="btnCancel">取消</button>
                            <button type="button" class="btn-tp-confirm" id="btnConfirm">确定</button>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-default btn-quick" id="btnLast15Min">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l3.5 2"/></svg>
                    最近15分钟
                </button>
            </div>
        </div>

        <input type="hidden" name="msg_min" value="1">

        <button type="submit" class="btn btn-primary btn-search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            搜索
            <img class="htmx-indicator" src="/img/oval.svg" width="13">
        </button>
    </form>
</div>

<script>
(function () {
    const pad = n => String(n).padStart(2, '0');
    const parseTime = s => { const p = (s||'00:00:00').split(':'); return [+p[0]||0, +p[1]||0, +p[2]||0]; };
    const fmtTime = (h,m,s) => `${pad(h)}:${pad(m)}:${pad(s)}`;

    let sv = parseTime('<%= start %>');
    let ev = parseTime('<%= stop %>');
    let tmp = { s: [...sv], e: [...ev] };

    const previewStart = document.getElementById('previewStart');
    const previewEnd   = document.getElementById('previewEnd');
    function updatePreview() {
        previewStart.textContent = fmtTime(...tmp.s);
        previewEnd.textContent   = fmtTime(...tmp.e);
    }

    function buildCol(el, max, getVal, setVal) {
        const prev = document.createElement('span');
        const curr = document.createElement('span');
        const next = document.createElement('span');
        prev.className = 'adj'; next.className = 'adj';
        el.append(prev, curr, next);

        function render() {
            const v = getVal();
            prev.textContent = pad((v - 1 + max) % max);
            curr.textContent = pad(v); curr.className = 'selected';
            next.textContent = pad((v + 1) % max);
        }
        render();

        prev.addEventListener('click', () => { setVal((getVal() - 1 + max) % max); render(); updatePreview(); });
        next.addEventListener('click', () => { setVal((getVal() + 1) % max); render(); updatePreview(); });

        return render;
    }

    const cols = [
        buildCol(document.getElementById('col-sh'), 24, () => tmp.s[0], v => tmp.s[0] = v),
        buildCol(document.getElementById('col-sm'), 60, () => tmp.s[1], v => tmp.s[1] = v),
        buildCol(document.getElementById('col-ss'), 60, () => tmp.s[2], v => tmp.s[2] = v),
        buildCol(document.getElementById('col-eh'), 24, () => tmp.e[0], v => tmp.e[0] = v),
        buildCol(document.getElementById('col-em'), 60, () => tmp.e[1], v => tmp.e[1] = v),
        buildCol(document.getElementById('col-es'), 60, () => tmp.e[2], v => tmp.e[2] = v),
    ];

    const display = document.getElementById('timeDisplay');
    const popup   = document.getElementById('timePopup');
    const displayText = document.getElementById('timeDisplayText');

    function updateDisplay() {
        displayText.textContent = fmtTime(...sv) + ' 至 ' + fmtTime(...ev);
        document.getElementById('inputStart').value = fmtTime(...sv);
        document.getElementById('inputStop').value  = fmtTime(...ev);
    }

    function openPopup() {
        tmp = { s: [...sv], e: [...ev] };
        cols.forEach(r => r());
        updatePreview();
        popup.classList.add('open');
    }

    display.addEventListener('click', () => popup.classList.contains('open') ? popup.classList.remove('open') : openPopup());
    display.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openPopup(); } });
    document.getElementById('btnConfirm').addEventListener('click', () => { sv = [...tmp.s]; ev = [...tmp.e]; updateDisplay(); popup.classList.remove('open'); });
    document.getElementById('btnCancel').addEventListener('click', () => popup.classList.remove('open'));
    document.addEventListener('click', e => { if (!display.closest('.time-picker-wrap').contains(e.target)) popup.classList.remove('open'); });

    document.getElementById('btnLast15Min').addEventListener('click', () => {
        const now = new Date();
        const todayStr = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;
        const endSec = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();
        const startSec = Math.max(0, endSec - 900);
        const toHMS = sec => [Math.floor(sec / 3600), Math.floor((sec % 3600) / 60), sec % 60];
        sv = toHMS(startSec);
        ev = toHMS(endSec);
        tmp = { s: [...sv], e: [...ev] };
        cols.forEach(r => r());
        updatePreview();
        const dayInput = document.querySelector('input[name="day"]');
        if (dayInput) dayInput.value = todayStr;
        updateDisplay();
        popup.classList.remove('open');
    });
})();
</script>
