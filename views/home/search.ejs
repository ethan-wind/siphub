<div class="search-bar">
    <form class="search-row" hx-post="/api/record" hx-target="#cdr" hx-swap="innerHTML">
        <div class="field-group">
            <span class="field-label">时间：</span>
            <div class="time-picker-wrap">
                <div class="time-display" tabindex="0" id="timeDisplay">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span id="timeDisplayText"><%= start %> — <%= stop %></span>
                </div>
                <input type="hidden" name="start" id="inputStart" value="<%= start %>">
                <input type="hidden" name="stop"  id="inputStop"  value="<%= stop %>">
                <div class="time-popup" id="timePopup">
                    <div class="time-popup-header"><div>开始时间</div><div>结束时间</div></div>
                    <div class="time-cols">
                        <div class="time-col-group">
                            <div class="time-col" id="col-sh"></div>
                            <span class="time-col-sep">:</span>
                            <div class="time-col" id="col-sm"></div>
                            <span class="time-col-sep">:</span>
                            <div class="time-col" id="col-ss"></div>
                        </div>
                        <div class="time-col-group">
                            <div class="time-col" id="col-eh"></div>
                            <span class="time-col-sep">:</span>
                            <div class="time-col" id="col-em"></div>
                            <span class="time-col-sep">:</span>
                            <div class="time-col" id="col-es"></div>
                        </div>
                    </div>
                    <div class="time-popup-footer">
                        <button type="button" class="btn-tp-cancel" id="btnCancel">取消</button>
                        <button type="button" class="btn-tp-confirm" id="btnConfirm">确定</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <div class="field-group">
            <span class="field-label">日期：</span>
            <input name="day" type="date" value="<%= day %>" class="field-input w-160">
        </div>

        <div class="divider"></div>

        <div class="field-group">
            <span class="field-label">主叫：</span>
            <input name="caller" type="text" placeholder="请输入主叫" class="field-input w-160">
        </div>

        <div class="field-group">
            <span class="field-label">被叫：</span>
            <input name="callee" type="text" placeholder="请输入被叫" class="field-input w-160">
        </div>

        <input type="hidden" name="msg_min" value="1">

        <button type="submit" class="btn btn-primary" style="margin-left:auto">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            搜索
            <img class="htmx-indicator" src="/img/oval.svg" width="13">
        </button>
    </form>
</div>

<script>
(function () {
    const pad = n => String(n).padStart(2, '0');
    const parseTime = s => { const p = (s||'00:00:00').split(':'); return [+p[0]||0, +p[1]||0, +p[2]||0]; };
    const fmtTime = (h,m,s) => `${pad(h)}:${pad(m)}:${pad(s)}`;

    let sv = parseTime('<%= start %>');
    let ev = parseTime('<%= stop %>');
    let tmp = { s: [...sv], e: [...ev] };

    const ITEM_H = 32, OFFSET = 2;

    function buildCol(el, max, getVal, setVal) {
        const inner = document.createElement('div');
        inner.className = 'time-col-inner';
        for (let i = 0; i < OFFSET; i++) inner.appendChild(Object.assign(document.createElement('span'), {textContent: ''}));
        for (let v = 0; v < max; v++) {
            const s = document.createElement('span');
            s.textContent = pad(v); s.dataset.v = v;
            inner.appendChild(s);
        }
        for (let i = 0; i < OFFSET; i++) inner.appendChild(Object.assign(document.createElement('span'), {textContent: ''}));
        el.appendChild(inner);

        function scrollTo(val, animate) {
            inner.style.transition = animate ? 'transform 0.15s ease' : 'none';
            inner.style.transform = `translateY(${-val * ITEM_H}px)`;
            inner.querySelectorAll('span[data-v]').forEach(s => s.classList.toggle('selected', +s.dataset.v === val));
        }
        scrollTo(getVal(), false);

        el.addEventListener('wheel', e => {
            e.preventDefault();
            const next = Math.max(0, Math.min(max-1, getVal() + (e.deltaY > 0 ? 1 : -1)));
            setVal(next); scrollTo(next, true);
        }, { passive: false });

        let startY, startVal;
        el.addEventListener('pointerdown', e => { startY = e.clientY; startVal = getVal(); el.setPointerCapture(e.pointerId); });
        el.addEventListener('pointermove', e => {
            if (startY == null) return;
            const next = Math.max(0, Math.min(max-1, startVal + Math.round((startY - e.clientY) / ITEM_H)));
            setVal(next); scrollTo(next, false);
        });
        el.addEventListener('pointerup', () => { startY = null; });

        return () => scrollTo(getVal(), false);
    }

    const cols = [
        buildCol(document.getElementById('col-sh'), 24, () => tmp.s[0], v => tmp.s[0] = v),
        buildCol(document.getElementById('col-sm'), 60, () => tmp.s[1], v => tmp.s[1] = v),
        buildCol(document.getElementById('col-ss'), 60, () => tmp.s[2], v => tmp.s[2] = v),
        buildCol(document.getElementById('col-eh'), 24, () => tmp.e[0], v => tmp.e[0] = v),
        buildCol(document.getElementById('col-em'), 60, () => tmp.e[1], v => tmp.e[1] = v),
        buildCol(document.getElementById('col-es'), 60, () => tmp.e[2], v => tmp.e[2] = v),
    ];

    const display = document.getElementById('timeDisplay');
    const popup   = document.getElementById('timePopup');
    const displayText = document.getElementById('timeDisplayText');

    function updateDisplay() {
        displayText.textContent = fmtTime(...sv) + ' — ' + fmtTime(...ev);
        document.getElementById('inputStart').value = fmtTime(...sv);
        document.getElementById('inputStop').value  = fmtTime(...ev);
    }

    function openPopup() {
        tmp = { s: [...sv], e: [...ev] };
        cols.forEach(r => r());
        popup.classList.add('open');
    }

    display.addEventListener('click', () => popup.classList.contains('open') ? popup.classList.remove('open') : openPopup());
    display.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openPopup(); } });
    document.getElementById('btnConfirm').addEventListener('click', () => { sv = [...tmp.s]; ev = [...tmp.e]; updateDisplay(); popup.classList.remove('open'); });
    document.getElementById('btnCancel').addEventListener('click', () => popup.classList.remove('open'));
    document.addEventListener('click', e => { if (!display.closest('.time-picker-wrap').contains(e.target)) popup.classList.remove('open'); });
})();
</script>
